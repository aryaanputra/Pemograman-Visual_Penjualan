	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Penjualan.jrdax"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value="cGVuanVhbGFuLnBlbWVzYW5hbiBBUyAsMzcsNDEsMTFmNjU5ODUtMDA2Yy00NDg4LWFjM2MtNmNj&#xa;ODMxNzZmNGU3O3Blbmp1YWxhbi5kZXRhaWxfcGVtZXNhbmFuIEFTICwyMzMsNDgsYmE1YTk2NGMt&#xa;ZDgxYS00YTJkLTg4NzItMGU3YzRlMThlNDRiOw=="/>
	<query language="sql"><![CDATA[SELECT penjualan.pemesanan.no_faktur,
	penjualan.pemesanan.nama_pelanggan,
	penjualan.pemesanan.tanggal,
	penjualan.pemesanan.total,
	penjualan.pemesanan.bayar,
	penjualan.pemesanan.kembalian,
	penjualan.detail_pemesanan.jumlah,
	penjualan.detail_pemesanan.harga_jual,
	penjualan.detail_pemesanan.nama_barang,
	penjualan.detail_pemesanan.id_barang
FROM penjualan.detail_pemesanan
	INNER JOIN penjualan.pemesanan ON 
	 penjualan.detail_pemesanan.no_faktur = penjualan.pemesanan.no_faktur]]></query>
